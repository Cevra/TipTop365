// System of record: PostgreSQL on Neon (plan D3).
// DATABASE_URL  = pooled connection (app runtime)
// DIRECT_URL    = unpooled connection (migrations)
// Prisma CLI reads .env, not .env.local — npm scripts wrap with `dotenv -e .env.local`.
// Domain models land block-by-block through E1 (plan §4). E1.1 = identity block.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Admin-togglable feature flags (plan D12). One row per flag; `payload` carries
// optional structured config. An env var (FLAG_<KEY>=true|false) overrides the
// DB value at read time — see lib/server/featureFlags.ts.
model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  payload   Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

// ---------------------------------------------------------------------------
// Identity block (E1.1, plan §4). Money = integer fenings (D5): *_f columns.
// Locale is a plain string (mirrors i18n/routing.ts union), not a DB enum.
// ---------------------------------------------------------------------------

enum UserRole {
  customer
  cleaner
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum CleanerTier {
  registered
  verified
}

// D19 seam: only `marketplace` is implemented; the other values exist so the
// Batmaid-trio growth path (§21) never needs a money-table migration.
enum EngagementModel {
  marketplace
  payroll_service
  employed
}

enum LegalRegime {
  fbih
  fbih_student
  rs
  brcko
  obrt
}

enum VerificationStatus {
  applied
  interview_scheduled
  checklist
  approved
  rejected
}

enum InterviewMode {
  video
  in_person
}

enum PropertyType {
  apartment
  house
  office
  vacation_rental
}

model User {
  id           String     @id @default(cuid())
  firebaseUid  String     @unique @map("firebase_uid")
  email        String     @unique
  phone        String?
  firstName    String?    @map("first_name")
  lastName     String?    @map("last_name")
  role         UserRole   @default(customer)
  locale       String     @default("bs")
  status       UserStatus @default(active)
  isHost       Boolean    @default(false) @map("is_host")
  referralCode String?    @unique @map("referral_code")
  referredById String?    @map("referred_by_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  referredBy            User?                     @relation("UserReferrals", fields: [referredById], references: [id])
  referrals             User[]                    @relation("UserReferrals")
  cleanerProfile        CleanerProfile?
  cleanerLegalProfile   CleanerLegalProfile?
  verificationApps      VerificationApplication[] @relation("VerificationApplicant")
  reviewedVerifications VerificationApplication[] @relation("VerificationReviewer")
  properties            Property[]
  bookingsAsCustomer    Booking[]
  recurringPlans        RecurringPlan[]
  chatMessages          ChatMessage[]
  bookingEvents         BookingEvent[]

  @@map("users")
}

model City {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  active      Boolean  @default(true)
  launchStage String?  @map("launch_stage")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cleanerProfiles CleanerProfile[]
  properties      Property[]
  pricingConfigs  PricingConfig[]

  @@map("cities")
}

model CleanerProfile {
  id              String          @id @default(cuid())
  userId          String          @unique @map("user_id")
  bio             String?
  photoUrl        String?         @map("photo_url")
  gender          String?
  hourlyRateF     Int?            @map("hourly_rate_f")
  cityId          String?         @map("city_id")
  serviceRadiusKm Float?          @map("service_radius_km")
  lat             Float?
  lng             Float?
  // Weekly slots jsonb — existing shape from lib/shared/types.ts Availability.
  availability    Json?
  tier            CleanerTier     @default(registered)
  verifiedAt      DateTime?       @map("verified_at")
  idChecked       Boolean         @default(false) @map("id_checked")
  languages       String[]        @default([])
  ratingAvg       Float?          @map("rating_avg")
  ratingCount     Int             @default(0) @map("rating_count")
  acceptsCash     Boolean         @default(true) @map("accepts_cash")
  active          Boolean         @default(true)
  engagementModel EngagementModel @default(marketplace) @map("engagement_model")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user                      User              @relation(fields: [userId], references: [id])
  city                      City?             @relation(fields: [cityId], references: [id])
  services                  CleanerService[]
  bookingsAsCleaner         Booking[]
  bookingOffers             BookingOffer[]
  priceAdjustmentsRequested PriceAdjustment[]
  preferredInPlans          RecurringPlan[]

  @@index([cityId, active, tier])
  @@map("cleaner_profiles")
}

model CleanerLegalProfile {
  id                     String       @id @default(cuid())
  cleanerId              String       @unique @map("cleaner_id")
  legalRegime            LegalRegime? @map("legal_regime")
  entityOfResidence      String?      @map("entity_of_residence")
  isStudent              Boolean      @default(false) @map("is_student")
  studentProofUrl        String?      @map("student_proof_url")
  studentProofValidUntil DateTime?    @map("student_proof_valid_until")
  obrtIdNumber           String?      @map("obrt_id_number")
  obrtRegistered         Boolean      @default(false) @map("obrt_registered")
  // AES-GCM ciphertext, written only by the contract layer (E7) — never plaintext.
  jmbgEncrypted          String?      @map("jmbg_encrypted")
  bankAccountIban        String?      @map("bank_account_iban")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  cleaner User @relation(fields: [cleanerId], references: [id])

  @@map("cleaner_legal_profiles")
}

model VerificationApplication {
  id              String             @id @default(cuid())
  cleanerId       String             @map("cleaner_id")
  status          VerificationStatus @default(applied)
  interviewAt     DateTime?          @map("interview_at")
  interviewMode   InterviewMode?     @map("interview_mode")
  // { id_verified, references_checked, trial_cleaning, notes } — admin checklist.
  checklist       Json?
  reviewedById    String?            @map("reviewed_by_id")
  rejectionReason String?            @map("rejection_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  cleaner    User  @relation("VerificationApplicant", fields: [cleanerId], references: [id])
  reviewedBy User? @relation("VerificationReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([cleanerId])
  @@map("verification_applications")
}

model Property {
  id          String       @id @default(cuid())
  ownerId     String       @map("owner_id")
  label       String?
  type        PropertyType @default(apartment)
  cityId      String?      @map("city_id")
  street      String?
  houseNo     String?      @map("house_no")
  floor       String?
  hasElevator Boolean      @default(false) @map("has_elevator")
  lat         Float?
  lng         Float?
  sizeM2      Int?         @map("size_m2")
  rooms       Int?
  bathrooms   Int?
  pets        Boolean      @default(false)
  accessNotes String?      @map("access_notes")
  // Host checklist items: linens / restock / damage-report (§4 properties).
  checklist   Json?
  isAirbnb    Boolean      @default(false) @map("is_airbnb")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  owner          User            @relation(fields: [ownerId], references: [id])
  city           City?           @relation(fields: [cityId], references: [id])
  bookings       Booking[]
  recurringPlans RecurringPlan[]

  @@index([ownerId])
  @@map("properties")
}

// ---------------------------------------------------------------------------
// Catalog block (E1.2, plan §4 "Catalog & pricing — all admin-editable, no
// hardcoding"). `key` fields are plain strings, not enums: the whole point of
// this block is that admins add/edit catalog rows without a migration. Only
// `unit` (a fixed unit-of-measure the pricing engine branches on) is an enum.
// ---------------------------------------------------------------------------

enum AddonUnit {
  fixed
  per_window
  per_hour
  per_m2
}

model ServiceType {
  id                 String   @id @default(cuid())
  key                String   @unique
  nameBs             String   @map("name_bs")
  nameEn             String   @map("name_en")
  // Applied to the m²-band base hours, e.g. deep=1.6, move_out=1.8, airbnb=0.9.
  durationMultiplier Float    @map("duration_multiplier")
  requiresVerified   Boolean  @default(false) @map("requires_verified")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  cleanerServices CleanerService[]
  bookings        Booking[]
  recurringPlans  RecurringPlan[]

  @@map("service_types")
}

model Addon {
  id        String    @id @default(cuid())
  key       String    @unique
  nameBs    String    @map("name_bs")
  nameEn    String    @map("name_en")
  hours     Float
  unit      AddonUnit
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  bookingAddons BookingAddon[]

  @@map("addons")
}

// Many-to-many: which service types a cleaner offers.
model CleanerService {
  id               String   @id @default(cuid())
  cleanerProfileId String   @map("cleaner_profile_id")
  serviceTypeId    String   @map("service_type_id")
  createdAt        DateTime @default(now()) @map("created_at")

  cleanerProfile CleanerProfile @relation(fields: [cleanerProfileId], references: [id])
  serviceType    ServiceType    @relation(fields: [serviceTypeId], references: [id])

  @@unique([cleanerProfileId, serviceTypeId])
  @@map("cleaner_services")
}

// Versioned per-city pricing configuration (§5/§6). Bookings (E1.3) snapshot
// `pricing_config_version` so historical bookings never reprice when an admin
// publishes a new version — see plan §4 bookings row + gate G2.
model PricingConfig {
  id      String  @id @default(cuid())
  cityId  String  @map("city_id")
  version Int
  active  Boolean @default(false)

  // [{ maxM2: 40, hours: 2.0 }, …] + a top-level extraPer40M2 factor.
  m2Bands Json @map("m2_bands")

  rateMinF Int @map("rate_min_f")
  rateMaxF Int @map("rate_max_f")

  // Percentage points (20 = 20%), not money — D5 integer-fenings applies to
  // amounts, not rates. Money-typed *_f fields below stay integer fenings.
  platformFeePct Float @map("platform_fee_pct")

  // { weekly: 10, biweekly: 7, monthly: 5 } — percentage points per frequency.
  recurringDiscountPct Json @map("recurring_discount_pct")

  cashFeeF Int? @map("cash_fee_f")

  // [{ hoursBefore: 24, refundPct: 100 }, { hoursBefore: 0, refundPct: 50 },
  //  { noShow: true, refundPct: 0 }]
  cancellationRules Json @map("cancellation_rules")

  // Not yet specified by the plan beyond the column name — plain string so
  // admin can set whatever the eventual VAT policy needs without a migration.
  vatMode String? @map("vat_mode")

  negativeBalanceLimitF Int @default(-5000) @map("negative_balance_limit_f")
  autoConfirmHours      Int @default(48) @map("auto_confirm_hours")
  minAfterPhotosPerRoom Int @default(2) @map("min_after_photos_per_room")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city City @relation(fields: [cityId], references: [id])

  // E2.3 (admin publish flow) owns the "exactly one active version per city"
  // invariant; this unique constraint only guards against duplicate versions.
  @@unique([cityId, version])
  @@index([cityId, active])
  @@map("pricing_configs")
}

// ---------------------------------------------------------------------------
// Booking block (E1.3, plan §4/§5). Schema only — the FSM transition table is
// E3.4, the pricing math is E2.1, matching/offers logic is E3.3/E3.6. Status
// values are exactly the §5 state-machine diagram's states, no invention.
// `location_pings` is intentionally NOT here — it's built in E4.6.
// ---------------------------------------------------------------------------

enum BookingStatus {
  draft
  pending_payment
  matching
  accepted
  on_my_way
  in_progress
  pending_completion
  completed
  disputed
  refunded
  cancelled
  expired
}

enum PaymentMethod {
  card
  cash
}

enum MatchingMode {
  direct
  broadcast
}

// Shared actor vocabulary for booking_events.actor_type and bookings.cancelled_by.
enum BookingActorType {
  customer
  cleaner
  admin
  system
}

enum BookingOfferStatus {
  offered
  seen
  accepted
  declined
  expired
  lost_race
}

enum RecurringFrequency {
  weekly
  biweekly
  monthly
}

enum PriceAdjustmentStatus {
  requested
  approved
  rejected
}

enum ChatFlagReason {
  phone
  email
  social
}

model Booking {
  id            String        @id @default(cuid())
  code          String        @unique
  customerId    String        @map("customer_id")
  propertyId    String        @map("property_id")
  // References cleaner_profiles.id (ERD: cleaner_profiles ||--o{ bookings), not users.id.
  cleanerId     String?       @map("cleaner_id")
  serviceTypeId String        @map("service_type_id")
  status        BookingStatus @default(draft)

  scheduledAt     DateTime @map("scheduled_at")
  slotMinutes     Int      @map("slot_minutes")
  recurringPlanId String?  @map("recurring_plan_id")

  estHours Float @map("est_hours")

  // Money: integer fenings (D5).
  cleanerRateF   Int    @map("cleaner_rate_f")
  cleanerAmountF Int    @map("cleaner_amount_f")
  serviceFeeF    Int    @map("service_fee_f")
  cashFeeF       Int    @map("cash_fee_f")
  discountF      Int    @map("discount_f")
  totalF         Int    @map("total_f")
  currency       String @default("BAM")

  paymentMethod PaymentMethod @map("payment_method")

  // Full pricing computation trace (§6) — historical bookings never reprice.
  pricingSnapshot      Json @map("pricing_snapshot")
  // Plain snapshot of pricing_configs.version at booking time — deliberately
  // NOT an FK, so a later pricing_configs edit/delete can never alter or break
  // a past booking's numbers (plan §6: "booking stores the snapshot").
  pricingConfigVersion Int  @map("pricing_config_version")

  matchingMode    MatchingMode    @map("matching_mode")
  // Snapshot from cleaner_profiles.engagement_model at booking time (D19).
  engagementModel EngagementModel @map("engagement_model")

  // contracts doesn't exist until E1.5 — plain column, no relation yet
  // (same deferred-FK pattern as cleaner_services was for E1.1/E1.2).
  contractId String? @map("contract_id")

  specialNotes       String?           @map("special_notes")
  cancelledBy        BookingActorType? @map("cancelled_by")
  cancellationReason String?           @map("cancellation_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer      User            @relation(fields: [customerId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  cleaner       CleanerProfile? @relation(fields: [cleanerId], references: [id])
  serviceType   ServiceType     @relation(fields: [serviceTypeId], references: [id])
  recurringPlan RecurringPlan?  @relation(fields: [recurringPlanId], references: [id])

  addons           BookingAddon[]
  events           BookingEvent[]
  offers           BookingOffer[]
  priceAdjustments PriceAdjustment[]
  chatMessages     ChatMessage[]

  @@index([customerId])
  @@index([cleanerId])
  @@index([status])
  @@index([scheduledAt])
  @@map("bookings")
}

model BookingAddon {
  id             String   @id @default(cuid())
  bookingId      String   @map("booking_id")
  addonId        String   @map("addon_id")
  qty            Int      @default(1)
  hoursSnapshot  Float    @map("hours_snapshot")
  priceFSnapshot Int      @map("price_f_snapshot")
  createdAt      DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  addon   Addon   @relation(fields: [addonId], references: [id])

  @@index([bookingId])
  @@map("booking_addons")
}

// Append-only audit trail of the FSM (E3.4 writes these; schema only here).
model BookingEvent {
  id         String           @id @default(cuid())
  bookingId  String           @map("booking_id")
  fromStatus BookingStatus?   @map("from_status")
  toStatus   BookingStatus    @map("to_status")
  actorType  BookingActorType @map("actor_type")
  // Null when actorType = system (no user actor, e.g. the auto-confirm job).
  actorId    String?          @map("actor_id")
  // e.g. GPS coords on check-in.
  meta       Json?
  createdAt  DateTime         @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([bookingId, createdAt])
  @@map("booking_events")
}

model BookingOffer {
  id        String             @id @default(cuid())
  bookingId String             @map("booking_id")
  cleanerId String             @map("cleaner_id")
  status    BookingOfferStatus @default(offered)
  expiresAt DateTime           @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  booking Booking        @relation(fields: [bookingId], references: [id])
  cleaner CleanerProfile @relation(fields: [cleanerId], references: [id])

  @@index([bookingId])
  @@index([cleanerId, status])
  @@map("booking_offers")
}

model RecurringPlan {
  id          String             @id @default(cuid())
  customerId  String             @map("customer_id")
  propertyId  String             @map("property_id")
  frequency   RecurringFrequency
  // Day-of-week convention finalized by the generator job (E3.10) — not
  // invented here; just an integer slot.
  weekday     Int?
  // "14:00" — matches the existing Availability { start, end } string convention.
  time        String
  active      Boolean            @default(true)
  nextRunDate DateTime           @map("next_run_date")

  // Booking template fields — a snapshot, not live FKs to a join table.
  serviceTypeId      String  @map("service_type_id")
  addonsTemplate     Json?   @map("addons_template")
  preferredCleanerId String? @map("preferred_cleaner_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer         User            @relation(fields: [customerId], references: [id])
  property         Property        @relation(fields: [propertyId], references: [id])
  serviceType      ServiceType     @relation(fields: [serviceTypeId], references: [id])
  preferredCleaner CleanerProfile? @relation(fields: [preferredCleanerId], references: [id])
  bookings         Booking[]

  @@index([active, nextRunDate])
  @@map("recurring_plans")
}

model PriceAdjustment {
  id            String                @id @default(cuid())
  bookingId     String                @map("booking_id")
  requestedById String                @map("requested_by_id")
  reason        String
  extraHours    Float                 @map("extra_hours")
  extraAmountF  Int                   @map("extra_amount_f")
  status        PriceAdjustmentStatus @default(requested)
  approvedAt    DateTime?             @map("approved_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  booking     Booking        @relation(fields: [bookingId], references: [id])
  requestedBy CleanerProfile @relation(fields: [requestedById], references: [id])

  @@index([bookingId])
  @@map("price_adjustments")
}

model ChatMessage {
  id         String          @id @default(cuid())
  bookingId  String          @map("booking_id")
  senderId   String          @map("sender_id")
  // Masking/contact-detection is E4.5 — this column just stores the (already
  // masked, per that future logic) body.
  body       String
  flagged    Boolean         @default(false)
  flagReason ChatFlagReason? @map("flag_reason")
  createdAt  DateTime        @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  sender  User    @relation(fields: [senderId], references: [id])

  @@index([bookingId, createdAt])
  @@map("chat_messages")
}
