# Copy to .env.local and fill in. Client-exposed keys are NEXT_PUBLIC_*.
# Full target list for later epics lives in docs/TECHNICAL_PLAN.md §16.

# Firebase web app (Auth + FCM) — Firebase console → project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Neon Postgres (plan D3) — pooled for runtime, direct for migrations
DATABASE_URL=
DIRECT_URL=

# Firebase admin service-account JSON file path (server-only, E0.3+)
FIREBASE_SERVICE_ACCOUNT_PATH=

# Observability & ops (plan D21 / docs/OPS.md) — all optional; app runs without them
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_RELEASE=
NEXT_PUBLIC_APP_ENV=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Nightly DB dump → Bunny storage (scripts/db-dump.mjs, backup.yml)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_HOST=
