rules_version = '2';

// TOMBSTONE (plan D3 v1.1). Firestore data access is decommissioned — Postgres
// is the only database and realtime is served by polling GET /bookings/:id/live.
// This rule set denies ALL client reads and writes. Do not add allowances here;
// if you think you need Firestore, you want a Postgres table + the /live channel.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
